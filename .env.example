PORT=5000
NODE_ENV=development
FRONTEND_URL=http://127.0.0.1:5500,http://localhost:5500,capacitor://localhost,http://localhost
BACKEND_URL=http://localhost:5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/tubepilot

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (used for Google Sign-In AND YouTube channel connect)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/youtube/oauth/callback

# Google Drive (3rd storage fallback) - same OAuth app, separate refresh token of storage owner account
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
GOOGLE_DRIVE_REFRESH_TOKEN=your_drive_account_refresh_token

# Cloudinary Account 1
CLOUDINARY_1_CLOUD_NAME=
CLOUDINARY_1_API_KEY=
CLOUDINARY_1_API_SECRET=
CLOUDINARY_1_MAX_GB=25

# Cloudinary Account 2 (backup)
CLOUDINARY_2_CLOUD_NAME=
CLOUDINARY_2_API_KEY=
CLOUDINARY_2_API_SECRET=
CLOUDINARY_2_MAX_GB=25

# Groq (AI title/description/tags)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Firebase Cloud Messaging - real phone push notifications (upload completed, payment approved, etc.)
# Get this from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# That downloads a JSON file — base64-encode its FULL content and paste the result here as one line.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Diamonds -> Upload cost
DIAMOND_COST_PER_UPLOAD=10
FREE_UPLOADS_PER_MONTH=20

# Admin
ADMIN_EMAIL=admin@tubepilot.com
ADMIN_PASSWORD=change_this_admin_password
